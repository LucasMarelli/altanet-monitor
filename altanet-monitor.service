[Unit]
Description=Altanet ST20 — Monitor de señal GSM
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
User=fabrifor
WorkingDirectory=/home/fabrifor
ExecStart=/usr/bin/python3 /home/fabrifor/altanet-monitor/altanet_monitor.py
Environment=PYTHONUNBUFFERED=1
Restart=on-failure
RestartSec=10

[Install]
WantedBy=multi-user.target
